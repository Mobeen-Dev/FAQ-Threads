<section class="faq-minimal" aria-labelledby="faq-minimal-title">
  <style>
    .faq-minimal {
      --max-width: 900px;
      --radius: 12px;
      --border: 1px solid rgba(0, 0, 0, 0.06);
      padding: 1rem;
      margin: 1rem auto;
      max-width: var(--max-width);
      font-family: Inter, system-ui, -apple-system, 'Segoe UI', Roboto, Arial;
      color: #111827;
    }

    /* Header */
    .faq-minimal__header {
      margin-bottom: 1rem;
    }

    .faq-minimal h2 {
      margin: 0;
      font-size: 1.3rem;
      letter-spacing: -0.02em;
    }

    .faq-minimal p.lead {
      margin: 0.2rem 0 0 0;
      color: #6b7280;
      font-size: 0.95rem;
    }

    /* LIST = SINGLE COLUMN ALWAYS */
    .faq-minimal__list {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }

    /* FAQ ITEM */
    .faq-minimal details {
      position: relative;
      background: linear-gradient(180deg, #ffffff, #fafafa);
      border: var(--border);
      border-radius: var(--radius);
      transition: all 0.25s ease;
      overflow: hidden;
    }

    /* left accent bar */
    .faq-minimal details::before {
      content: '';
      position: absolute;
      left: 0;
      top: 0;
      bottom: 0;
      width: 4px;
      background: linear-gradient(180deg, #6366f1, #22c55e);
      opacity: 0.5;
    }

    /* hover effect */
    .faq-minimal details:hover {
      transform: translateY(-2px);
      box-shadow: 0 10px 24px rgba(0, 0, 0, 0.06);
    }

    .faq-minimal details[open] {
      box-shadow: 0 12px 26px rgba(0, 0, 0, 0.08);
    }

    /* summary */
    .faq-minimal summary {
      list-style: none;
      cursor: pointer;
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 0.9rem 1rem;
      font-weight: 600;
      font-size: 1rem;
    }

    summary::-webkit-details-marker {
      display: none;
    }

    /* question text */
    .faq-question {
      padding-right: 10px;
    }

    /* Chevron icon */
    .chev {
      width: 28px;
      height: 28px;
      display: grid;
      place-items: center;
      border-radius: 50%;
      background: #f3f4f6;
      transition: all 0.25s ease;
    }

    details[open] .chev {
      transform: rotate(180deg);
      background: #6366f1;
      color: white;
    }

    /* Answer */
    .answer {
      padding: 0.75rem 1rem 1rem 1rem;
      color: #374151;
      font-size: 0.96rem;
      line-height: 1.5;
      border-top: 1px dashed rgba(0, 0, 0, 0.06);
      animation: fadeIn 0.25s ease;
    }

    .answer .metafield-rich_text_field p {
      margin: 0 0 0.5em 0;
    }

    .answer .metafield-rich_text_field p:last-child {
      margin-bottom: 0;
    }

    /* smooth appearance */
    @keyframes fadeIn {
      from {
        opacity: 0;
        transform: translateY(-4px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
  </style>

  {%- comment -%}
    Adjust this metafield path if your namespace/key is different.
  {%- endcomment -%}
  {% assign faq_metafield = product.metafields['app--333151272961'].faq_items %}

  <div class="faq-minimal__header">
    <div>
      <h2 id="faq-minimal-title">Frequently asked questions</h2>
      <p class="lead">Common questions about this product — quick answers.</p>
    </div>
  </div>

  {% if product and faq_metafield and faq_metafield.value %}
    {% assign faq_list = faq_metafield.value %}
    <div class="faq-minimal__list" role="list">
      {% for faq_item in faq_list %}
        {%- comment -%}
          Skip items that are missing question or answer.
          Show only items with status 'active' (if you want that).
        {%- endcomment -%}
        {% assign question = '' %}
        {% if faq_item.question %}
          {% assign question = faq_item.question.value %}
        {% endif %}
        {% assign answer_raw = faq_item.answer %}
        {% assign answer = '' %}
        {% if answer_raw %}
          {% assign answer = answer_raw | metafield_tag %}
        {% endif %}
        {% assign status = '' %}
        {% if faq_item.status %}
          {% assign status = faq_item.status.value %}
        {% endif %}
        {% if question and answer and status == 'active' %}
          <details role="listitem" aria-labelledby="faq-{{ forloop.index0 }}-q">
            <summary id="faq-{{ forloop.index0 }}-q" aria-controls="faq-{{ forloop.index0 }}-a">
              <span class="faq-question">{{ question }}</span>
              <span class="chev" aria-hidden="true">
                <!-- simple SVG chevron -->
                <svg
                  width="14"
                  height="14"
                  viewBox="0 0 24 24"
                  fill="none"
                  xmlns="http://www.w3.org/2000/svg"
                  aria-hidden="true"
                >
                  <path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
            </summary>

            <div
              id="faq-{{ forloop.index0 }}-a"
              class="answer"
              role="region"
              aria-labelledby="faq-{{ forloop.index0 }}-q"
            >
              {%- comment -%}
                If your answers include HTML (rich text) you may want to print them raw.
                If not, this will be plain text. Adjust as needed.
              {%- endcomment -%}
              {{ answer }}
              {%- if faq_item.external_id and faq_item.external_id.value -%}
                <div style="margin-top:.5rem; font-size:.85rem; color:#6b7280;">
                  ID: {{ faq_item.external_id.value }}
                </div>
              {%- endif -%}
            </div>
          </details>
        {% endif %}
      {% endfor %}
    </div>

    {%- comment -%}
      Optional: If no visible items after filtering, show a friendly message.
    {%- endcomment -%}
    {% capture visible_count %}
      {% assign c = 0 %}
      {% for faq_item in faq_list %}
        {% assign question = "" %}
        {% if faq_item.question %}
          {% assign question = faq_item.question.value %}
        {% endif %}
        {% assign answer = "" %}
        {% if faq_item.answer %}
          {% assign answer = faq_item.answer | metafield_tag %}
        {% endif %}
        {% if question and answer %}
          {% assign c = c | plus: 1 %}
        {% endif %}
      {% endfor %}
      {{ c }}
    {% endcapture %}
    {% if visible_count == '0' %}
      <p style="margin-top:0.75rem; color:#6b7280;">No FAQ items available for this product.</p>
    {% endif %}

  {% else %}
    <p style="color:#6b7280;">No FAQ metafield found on this product. (Check metafield namespace/key)</p>
  {% endif %}

  <script>
    /* Optional: make the FAQ behave like an accordion (only one open at a time).
       This script is tiny and progressive — it only runs when JS is enabled. */
    (function () {
      if (!('querySelectorAll' in document)) return;
      var container = document.currentScript && document.currentScript.parentNode;
      if (!container) container = document;
      var details = container.querySelectorAll('details');
      if (!details || details.length <= 1) return;

      details.forEach(function (d) {
        d.addEventListener('toggle', function (e) {
          if (!d.open) return;
          // close other open details
          details.forEach(function (other) {
            if (other !== d && other.open) other.open = false;
          });
        });
      });
    })();
  </script>
</section>

{% schema %}
{
  "name": "FAQ — Minimal (product)",
  "settings": [],
  "target": "section",
  "enabled_on": { "templates": ["product"] }
}
{% endschema %}
