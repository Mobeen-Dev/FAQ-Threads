# Backend Environment Variables
DATABASE_URL="postgresql://user:password@localhost:5434/faq_app?schema=public"

# Server
PORT=4004
FRONTEND_URL=http://localhost:3004
BACKEND_URL=http://localhost:4004
# Optional public base URL override for webhook URLs shown to clients
# Use this when backend runs behind a proxy/tunnel and internal host is localhost
PUBLIC_BACKEND_URL=https://your-public-api-domain.com

# Authentication
JWT_SECRET=your-jwt-secret-change-in-production-min-32-chars
JWT_EXPIRES_IN=7d

# ─── Email Configuration ─────────────────────────────────────────
# Provider Selection: Configure RESEND_API_KEY (preferred) or SMTP settings
# If both are configured, Resend will be used first.

# ─── Option 1: Resend (Recommended) ──────────────────────────────
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here

# ─── Option 2: SMTP (Fallback) ───────────────────────────────────
# Works with any SMTP service: SendGrid, Mailgun, AWS SES, etc.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password

# ─── Sender Configuration ────────────────────────────────────────
EMAIL_FROM_NAME=FAQ Manager
EMAIL_FROM_ADDRESS=noreply@yourdomain.com
EMAIL_REPLY_TO=support@yourdomain.com

# Token Security (minimum 32 characters)
EMAIL_TOKEN_SECRET=your-email-token-secret-change-in-production-32chars
PASSWORD_RESET_EXPIRY_HOURS=1
EMAIL_VERIFY_EXPIRY_HOURS=24

# Email Queue Settings
EMAIL_QUEUE_ENABLED=true
EMAIL_RETRY_ATTEMPTS=3
EMAIL_RETRY_DELAY_MS=60000
EMAIL_BATCH_SIZE=10

# Report Scheduling (cron expressions)
ENABLE_REPORT_EMAILS=true
REPORT_CRON_DAILY=0 8 * * *
REPORT_CRON_WEEKLY=0 8 * * 1
REPORT_CRON_MONTHLY=0 8 1 * *
REPORT_TIMEZONE=UTC

# Feature Flags
SEND_WELCOME_EMAIL=true
REQUIRE_EMAIL_VERIFICATION=false
ENABLE_UNSUBSCRIBE=true

# Development Options
EMAIL_PREVIEW_MODE=false
EMAIL_LOG_LEVEL=info

# ─── MCP Server (AI App Integration) ───────────────────────────────
# Optional API base override for MCP tools. If omitted, BACKEND_URL/api is used.
FAQ_MCP_API_BASE_URL=http://localhost:4004/api

# Authentication for MCP server (choose ONE approach):
# 1) Direct token
# FAQ_MCP_TOKEN=your-jwt-token
#
# 2) Login credentials (MCP server logs in automatically and refreshes on 401)
# FAQ_MCP_EMAIL=admin@example.com
# FAQ_MCP_PASSWORD=your-password

# Optional network timeout in milliseconds for MCP -> backend calls
FAQ_MCP_TIMEOUT_MS=30000
