<h2>Verify Your Email Address</h2>

<p>Hi<% if (userName) { %> <strong><%= userName %></strong><% } %>,</p>

<p>Please verify your email address to complete your account setup and unlock all features.</p>

<p style="text-align: center;">
  <a href="<%= verifyEmailUrl %>" class="btn">Verify Email Address</a>
</p>

<p class="muted">This link will expire in <%= expiryHours || 24 %> hours.</p>

<hr class="divider">

<p class="muted">
  If the button doesn't work, copy and paste this link into your browser:
</p>

<div class="code-box">
  <%= verifyEmailUrl %>
</div>

<div class="alert-box alert-warning">
  <strong>Didn't request this?</strong><br>
  If you didn't create an account with us, you can safely ignore this email.
</div>
