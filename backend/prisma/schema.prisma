generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Admin Users (dashboard owners) ─────────────────────────
model User {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String
  name          String?
  emailVerified Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  shops         Shop[]
  emailLogs     EmailLog[]
}

// ─── Shopify Stores ─────────────────────────────────────────
model Shop {
  id                String             @id @default(cuid())
  domain            String
  webhookKey        String?            @unique
  accessToken       String?
  apiKey            String?
  name              String?
  plan              String             @default("free")
  userId            String
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  categories        Category[]
  questions         Question[]
  products          Product[]
  answers           Answer[]
  votes             Vote[]
  contributors      StoreContributor[]
  settings          Setting?
  emailLogs         EmailLog[]
  installedAt       DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@unique([userId, domain])
}

model Product {
  id                String    @id @default(cuid())
  title             String
  firstImageUrl     String?   @map("first_image_url")
  frontendUrl       String    @map("frontend_url")
  externalProductId String?   @map("external_product_id")
  handle            String?
  sourceUrl         String?   @map("source_url")
  shopId            String
  shop              Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  questions         Question[]
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@unique([shopId, frontendUrl])
  @@index([shopId, handle])
  @@index([shopId, externalProductId])
}

// ─── FAQ Categories ─────────────────────────────────────────
model Category {
  id          String     @id @default(cuid())
  name        String
  description String?
  slug        String
  sortOrder   Int        @default(0)
  shopId      String
  shop        Shop       @relation(fields: [shopId], references: [id], onDelete: Cascade)
  questions   Question[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@unique([shopId, slug])
}

// ─── Questions ──────────────────────────────────────────────
model Question {
  id            String    @id @default(cuid())
  question      String
  answer        String    @db.Text
  status        String    @default("pending") // pending, published, rejected, draft, suspended
  sortOrder     Int       @default(0)
  views         Int       @default(0)
  helpful       Int       @default(0)
  notHelpful    Int       @default(0)
  voteScore     Int       @default(0)
  productId     String?
  productHandle String?
  productTitle  String?
  productRefId  String?   @map("product_id")
  product       Product?  @relation(fields: [productRefId], references: [id], onDelete: SetNull)
  customerName  String?
  customerEmail String?
  customerPhone String?
  customerId    String?
  contributorId String?
  contributor   StoreContributor? @relation(fields: [contributorId], references: [id], onDelete: SetNull)
  source        String    @default("dashboard") // dashboard, webhook, import
  categoryId    String?
  category      Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  shopId        String
  shop          Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  answers       Answer[]
  votes         Vote[]    @relation("QuestionVotes")
  publishedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([shopId, status])
  @@index([shopId, productId, status])
  @@index([shopId, productHandle, status])
  @@index([shopId, categoryId])
  @@index([shopId, voteScore])
  @@index([customerEmail])
  @@index([productRefId])
}

// ─── Answers (multiple per question) ────────────────────────
model Answer {
  id            String    @id @default(cuid())
  answerText    String    @db.Text
  status        String    @default("pending") // pending, published, rejected, suspended
  voteScore     Int       @default(0)
  contributorId String?
  contributor   StoreContributor? @relation(fields: [contributorId], references: [id], onDelete: SetNull)
  questionId    String
  question      Question  @relation(fields: [questionId], references: [id], onDelete: Cascade)
  shopId        String
  shop          Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  votes         Vote[]    @relation("AnswerVotes")
  source        String    @default("dashboard") // dashboard, webhook
  publishedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([questionId, status])
  @@index([shopId])
}

// ─── Votes (on questions or answers) ────────────────────────
model Vote {
  id            String    @id @default(cuid())
  voteValue     Int       // +1 or -1
  entityType    String    // "question" or "answer"
  contributorId String
  contributor   StoreContributor @relation(fields: [contributorId], references: [id], onDelete: Cascade)
  questionId    String?
  question      Question? @relation("QuestionVotes", fields: [questionId], references: [id], onDelete: Cascade)
  answerId      String?
  answer        Answer?   @relation("AnswerVotes", fields: [answerId], references: [id], onDelete: Cascade)
  shopId        String
  shop          Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([contributorId, entityType, questionId])
  @@unique([contributorId, entityType, answerId])
  @@index([shopId])
}

// ─── Storefront Contributors (customers who ask/answer/vote) ─
model StoreContributor {
  id        String     @id @default(cuid())
  email     String
  name      String?
  phone     String?
  externalId String?   // ID from ecommerce platform
  status    String     @default("active") // active, suspended
  trusted   Boolean    @default(false)
  shopId    String
  shop      Shop       @relation(fields: [shopId], references: [id], onDelete: Cascade)
  questions Question[]
  answers   Answer[]
  votes     Vote[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@unique([shopId, email])
  @@index([shopId, status])
}

// ─── Shop Settings (widget + publishing rules) ──────────────
model Setting {
  id                          String  @id @default(cuid())
  shopId                      String  @unique
  shop                        Shop    @relation(fields: [shopId], references: [id], onDelete: Cascade)

  // Widget config
  widgetEnabled               Boolean @default(true)
  widgetPosition              String  @default("bottom-right")
  primaryColor                String  @default("#6366f1")
  allowSubmission             Boolean @default(true)
  notifyEmail                 String?

  // Question publishing
  autoPublishQuestions        Boolean @default(false)
  manualPublishQuestions      Boolean @default(true)
  publishQuestionsAfterTimeEnabled Boolean @default(false)
  publishQuestionsAfterMinutes    Int     @default(0)
  publishQuestionsAfterHours      Int     @default(24)

  // Answer publishing
  autoPublishAnswers          Boolean @default(false)
  manualPublishAnswers        Boolean @default(true)
  publishAnswersAfterTimeEnabled  Boolean @default(false)
  publishAnswersAfterMinutes      Int     @default(0)
  publishAnswersAfterHours        Int     @default(24)
  autoPublishIfAnswersLessThan    Int     @default(0) // 0 = disabled

  // Moderation
  autoModeration              Boolean @default(false)
  trustedCustomerAutoPublish  Boolean @default(false)

  // ─── Email Notification Settings ─────────────────────────────
  // Alert emails
  emailAlertsEnabled          Boolean @default(true)
  emailAlertNewQuestion       Boolean @default(true)
  emailAlertNewAnswer         Boolean @default(true)
  emailAlertModeration        Boolean @default(true)
  emailAlertRecipients        String? // Comma-separated email addresses, defaults to notifyEmail

  // Report emails
  emailReportsEnabled         Boolean @default(false)
  emailReportFrequency        String  @default("weekly") // daily, weekly, monthly, none
  emailReportRecipients       String? // Comma-separated email addresses
  emailReportLastSent         DateTime?

  // Email preferences
  emailUnsubscribedTypes      String? // Comma-separated list of unsubscribed email types
}

// ─── Email Logs (audit trail for sent emails) ───────────────
model EmailLog {
  id            String    @id @default(cuid())
  emailType     String    // welcome, verify, password_reset, alert_question, alert_answer, report_daily, etc.
  recipient     String    // Email address
  subject       String
  status        String    @default("pending") // pending, queued, sent, delivered, failed, bounced
  messageId     String?   // Provider message ID
  errorMessage  String?   @db.Text
  metadata      String?   @db.Text // JSON: template vars, related entity IDs
  attempts      Int       @default(0)
  lastAttemptAt DateTime?
  sentAt        DateTime?
  deliveredAt   DateTime?
  openedAt      DateTime?
  clickedAt     DateTime?
  bouncedAt     DateTime?
  userId        String?
  user          User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  shopId        String?
  shop          Shop?     @relation(fields: [shopId], references: [id], onDelete: SetNull)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([shopId, emailType])
  @@index([userId, emailType])
  @@index([recipient])
  @@index([status])
  @@index([createdAt])
}

// ─── Email Queue (for background processing) ─────────────────
model EmailQueue {
  id            String    @id @default(cuid())
  emailType     String
  recipient     String
  subject       String
  templateData  String    @db.Text // JSON: template variables
  priority      Int       @default(0) // Higher = more urgent
  status        String    @default("pending") // pending, processing, completed, failed
  attempts      Int       @default(0)
  maxAttempts   Int       @default(3)
  lastError     String?   @db.Text
  scheduledFor  DateTime  @default(now())
  processedAt   DateTime?
  emailLogId    String?   // Link to EmailLog after sending
  idempotencyKey String?  @unique // Prevent duplicate sends
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([status, scheduledFor])
  @@index([priority])
}

// ─── Used Tokens (prevent token reuse) ───────────────────────
model UsedToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique // SHA-256 hash of the token
  tokenType String   // password_reset, email_verify, unsubscribe
  usedAt    DateTime @default(now())
  expiresAt DateTime // When to auto-cleanup

  @@index([expiresAt])
}
