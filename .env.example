# =============================================================================
# FAQ App Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values
# =============================================================================

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
DB_USER=faquser
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE
DB_NAME=faq_app
DB_PORT=5432

# -----------------------------------------------------------------------------
# Backend Configuration
# -----------------------------------------------------------------------------
NODE_ENV=production
BACKEND_PORT=4004
JWT_SECRET=CHANGE_ME_GENERATE_SECURE_64_CHAR_SECRET

# Public URLs (change these for your domain)
FRONTEND_URL=http://localhost:3004
BACKEND_URL=http://localhost:4004
PUBLIC_BACKEND_URL=http://localhost:4004

# -----------------------------------------------------------------------------
# Frontend Configuration
# -----------------------------------------------------------------------------
FRONTEND_PORT=3004
# API URL as seen from browser
NEXT_PUBLIC_API_URL=http://localhost:4004/api
