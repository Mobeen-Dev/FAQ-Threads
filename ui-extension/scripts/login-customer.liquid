{% comment %}
  App Block: Logged-in Test Block
  Purpose: Test whether we can detect a logged-in customer in a Theme App Extension block.

  Usage:
  - Install the app extension on the store.
  - In the Online Store theme editor, add this app block to a section (e.g. on the home page).
  - View the storefront as:
      1) a logged-out visitor
      2) a logged-in customer
    and verify that the messaging changes.
{% endcomment %}

<div class="logged-in-test-block" style="border: 1px solid #ddd; padding: 1rem; margin: 1rem 0;">
  {% if customer %}
    <h2 style="margin-bottom: 0.5rem;">Logged-in customer detected ✅</h2>
    <p style="margin-bottom: 0.5rem;">
      Welcome back,
      {% if customer.first_name %}
        {{ customer.first_name }}
      {% else %}
        valued customer
      {% endif %}
      !
    </p>

    <p style="margin-bottom: 0.5rem;">
      This content is only visible when a customer is logged in.
      You can now safely enable members-only features here.
    </p>

    <ul style="margin-bottom: 0.5rem;">
      <li>Customer ID: {{ customer.id }}</li>
      <li>Email: {{ customer.email }}</li>
    </ul>

    {% if section.settings.show_debug_json %}
      <details style="margin-top: 0.5rem;">
        <summary>Debug: full customer JSON</summary>
        <pre style="white-space: pre-wrap; word-break: break-word;">
{{ customer | json }}
        </pre>
      </details>
    {% endif %}
  {% else %}
    <h2 style="margin-bottom: 0.5rem;">No logged-in customer ❌</h2>
    <p style="margin-bottom: 0.5rem;">
      You're currently browsing as a guest. This is what non-logged-in visitors will see.
    </p>

    <p style="margin-bottom: 0.5rem;">
      To access members-only features, please
      <a href="/account/login">log in</a>
      or
      <a href="/account/register">create an account</a>.
    </p>

    {% if section.settings.show_debug_json %}
      <p style="font-size: 0.9rem; color: #666;">
        Debug: <code>customer</code> is <code>{{ customer | json }}</code> (should be <code>null</code> when logged out).
      </p>
    {% endif %}
  {% endif %}
</div>

{% schema %}
{
  "name": "Logged-in test block",
  "target": "section",
  "settings": [
    {
      "type": "header",
      "content": "Logged-in status test"
    },
    {
      "type": "paragraph",
      "content": "This block tests whether the customer is logged in using the 'customer' Liquid object."
    },
    {
      "type": "checkbox",
      "id": "show_debug_json",
      "label": "Show debug JSON",
      "default": false
    }
  ]
}
{% endschema %}