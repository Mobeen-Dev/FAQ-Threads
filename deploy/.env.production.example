# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-this-password
POSTGRES_DB=faq_app
# Dedicated app credentials (required for backend app traffic)
DB_APP_USER=faq_app_user
DB_APP_PASSWORD=change-this-app-password
DATABASE_URL=postgresql://faq_app_user:change-this-app-password@postgres:5432/faq_app

# API/Web app URLs
FRONTEND_URL=https://your-frontend-domain.com
BACKEND_URL=https://your-backend-domain.com
NEXT_PUBLIC_API_URL=/api
INTERNAL_API_URL=http://backend:4004/api
ALLOWED_ORIGINS=https://your-frontend-domain.com

# Security
JWT_SECRET=replace-with-a-long-random-secret
