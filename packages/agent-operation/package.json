{
  "name": "@faq-app/agent-operation",
  "version": "1.0.0",
  "description": "Public MCP server for FAQ backend answer operations",
  "type": "module",
  "main": "src/server.mjs",
  "scripts": {
    "lint": "node --check src/cli.mjs && node --check src/server.mjs && node --check scripts/publish-guard.mjs",
    "test": "node --test tests/*.test.mjs",
